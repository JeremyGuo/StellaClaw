# ──────────────────────────────────────────────
# ClawParty 2.0 — System Architecture
# ──────────────────────────────────────────────

direction: down

title: |md
  # ClawParty 2.0 — System Architecture
  Layered overview: channels → session → agents → scheduling
| {
  near: top-center
  style: {
    font-size: 22
    font-color: "#f1f5f9"
    bold: true
  }
}

# ═══════════════ LAYER 1: CHANNELS ═══════════════

channels: CHANNELS {
  style: {
    fill: "#1a1a35"
    stroke: "#2a2a4a"
    border-radius: 12
    font-color: "#818cf8"
    font-size: 16
    bold: true
  }

  telegram: Telegram Bot {
    style: {
      fill: "#818cf8"
      font-color: "#ffffff"
      font-size: 16
      bold: true
      border-radius: 8
      stroke: "transparent"
    }
  }

  cli: CLI {
    style: {
      fill: "#6366f1"
      font-color: "#ffffff"
      font-size: 16
      bold: true
      border-radius: 8
      stroke: "transparent"
    }
  }

  future: "Future…" {
    style: {
      fill: "#4f46e5"
      font-color: "#ffffff"
      font-size: 16
      bold: true
      border-radius: 8
      stroke: "transparent"
    }
  }
}

# ═══════════════ LAYER 2: SESSION ═══════════════

session: SESSION {
  style: {
    fill: "#1a1a35"
    stroke: "#2a2a4a"
    border-radius: 12
    font-color: "#2dd4bf"
    font-size: 16
    bold: true
  }

  state: Persistent State + Attachments {
    style: {
      fill: "#2dd4bf"
      font-color: "#042f2e"
      font-size: 18
      bold: true
      border-radius: 8
      stroke: "transparent"
    }
  }
}

# ═══════════════ LAYER 3: AGENT TOPOLOGY ═══════════════

agents: AGENT TOPOLOGY {
  style: {
    fill: "#1a1a35"
    stroke: "#2a2a4a"
    border-radius: 12
    font-color: "#a78bfa"
    font-size: 16
    bold: true
  }

  workspace: |md
    **Workspace**
    durable, per-agent, isolated filesystem
  | {
    width: 620
    style: {
      fill: "#312e81"
      font-color: "#c7d2fe"
      font-size: 16
      border-radius: 8
      stroke: "transparent"
    }
  }

  foreground: |md
    **Main Foreground Agent**
    (user-facing)
  | {
    style: {
      fill: "#a78bfa"
      font-color: "#ffffff"
      font-size: 15
      border-radius: 8
      stroke: "transparent"
    }
  }

  background: |md
    **Main Background Agent**
    (long-running tasks)
  | {
    style: {
      fill: "#8b5cf6"
      font-color: "#ffffff"
      font-size: 15
      border-radius: 8
      stroke: "transparent"
    }
  }

  subagent: |md
    **Sub-Agent**
    (short-lived tasks)
  | {
    style: {
      fill: "#7c3aed"
      font-color: "#ffffff"
      font-size: 15
      border-radius: 8
      stroke: "transparent"
    }
  }

  # Peer arrows between agents
  foreground <-> background: {
    style: {
      stroke: "#6366f1"
      stroke-width: 2
      stroke-dash: 4
    }
  }

  background <-> subagent: {
    style: {
      stroke: "#6366f1"
      stroke-width: 2
      stroke-dash: 4
    }
  }

  # Agents → Workspace
  foreground -> workspace: {
    style: {
      stroke: "#a5b4fc"
      stroke-width: 2
    }
  }
  background -> workspace: {
    style: {
      stroke: "#a5b4fc"
      stroke-width: 2
    }
  }
  subagent -> workspace: {
    style: {
      stroke: "#a5b4fc"
      stroke-width: 2
    }
  }
}

# ═══════════════ LAYER 4: CRON / SINK ═══════════════

cron: CRON / SINK {
  style: {
    fill: "#1a1a35"
    stroke: "#2a2a4a"
    border-radius: 12
    font-color: "#fbbf24"
    font-size: 16
    bold: true
  }

  scheduled: Scheduled Tasks {
    style: {
      fill: "#fbbf24"
      font-color: "#451a03"
      font-size: 16
      bold: true
      border-radius: 8
      stroke: "transparent"
    }
  }

  routing: Direct Routing {
    style: {
      fill: "#f59e0b"
      font-color: "#451a03"
      font-size: 16
      bold: true
      border-radius: 8
      stroke: "transparent"
    }
  }

  broadcast: Broadcast Topics {
    style: {
      fill: "#d97706"
      font-color: "#451a03"
      font-size: 16
      bold: true
      border-radius: 8
      stroke: "transparent"
    }
  }
}

# ═══════════════ INTER-LAYER ARROWS ═══════════════

channels -> session: {
  style: {
    stroke: "#2dd4bf"
    stroke-width: 3
  }
}

session -> agents: {
  style: {
    stroke: "#a78bfa"
    stroke-width: 3
  }
}

agents -> cron: {
  style: {
    stroke: "#fbbf24"
    stroke-width: 3
  }
}
