{
  "version": "0.27",
  "models": {
    "main": {
      "backend": "agent_frame",
      "api_endpoint": "https://openrouter.ai/api/v1",
      "model": "openai/gpt-4o-mini",
      "supports_vision_input": true,
      "api_key_env": "OPENROUTER_API_KEY",
      "cache_ttl": "5m",
      "retry_mode": {
        "mode": "no"
      },
      "context_window_tokens": 128000,
      "token_estimation": {
        "template": {
          "source": "builtin"
        },
        "tokenizer": {
          "source": "tiktoken",
          "encoding": "auto"
        }
      },
      "native_web_search": {
        "enabled": false,
        "payload": {
          "web_search_options": {
            "search_context_size": "medium"
          }
        }
      },
      "description": "Fast general-purpose chat model for the foreground agent."
    },
    "brave_search": {
      "type": "brave-search",
      "api_endpoint": "https://api.search.brave.com",
      "model": "brave-web-search",
      "capabilities": [
        "web_search"
      ],
      "api_key_env": "BRAVE_SEARCH_API_KEY",
      "chat_completions_path": "/res/v1/web/search",
      "timeout_seconds": 30,
      "description": "Optional Brave Search helper for tooling.web_search.",
      "agent_model_enabled": false
    }
  },
  "tooling": {
    "web_search": "brave_search"
  },
  "main_agent": {
    "language": "zh-CN",
    "memory_system": "layered",
    "token_estimation_cache": {
      "template": {
        "hf": "template-cache/hf"
      },
      "tokenizer": {
        "hf": "tokenizer-cache/hf"
      }
    },
    "time_awareness": {
      "emit_system_date_on_user_message": false,
      "emit_idle_time_gap_hint": true
    },
    "context_compaction": {
      "trigger_ratio": 0.9,
      "token_limit_override": null,
      "recent_fidelity_target_ratio": 0.18
    },
    "idle_compaction": {
      "enabled": false,
      "poll_interval_seconds": 15,
      "min_ratio": 0.5
    },
    "timeout_observation_compaction": {
      "enabled": true
    }
  },
  "sandbox": {
    "mode": "subprocess",
    "bubblewrap_binary": "bwrap",
    "map_docker_socket": false
  },
  "channels": [
    {
      "kind": "command_line",
      "id": "local-cli",
      "prompt": "you> "
    },
    {
      "kind": "web",
      "id": "web-main",
      "listen_addr": "127.0.0.1:8080",
      "auth_token_env": "CLAWPARTY_WEB_AUTH_TOKEN"
    }
  ]
}
