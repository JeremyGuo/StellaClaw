{
  "version": "0.21",
  "models": {
    "main": {
      "backend": "agent_frame",
      "api_endpoint": "https://openrouter.ai/api/v1",
      "model": "openai/gpt-4o-mini",
      "supports_vision_input": true,
      "api_key_env": "OPENROUTER_API_KEY",
      "cache_ttl": "5m",
      "retry_mode": {
        "mode": "no"
      },
      "context_window_tokens": 128000,
      "native_web_search": {
        "enabled": true,
        "payload": {
          "web_search_options": {
            "search_context_size": "medium"
          }
        }
      },
      "external_web_search": {
        "base_url": "https://openrouter.ai/api/v1",
        "model": "perplexity/sonar",
        "api_key_env": "OPENROUTER_API_KEY",
        "chat_completions_path": "/chat/completions",
        "timeout_seconds": 60,
        "headers": {
          "HTTP-Referer": "https://example.com",
          "X-Title": "AgentHost External Search"
        }
      },
      "description": "Fast general-purpose chat model for the foreground agent."
    }
  },
  "main_agent": {
    "model": "main",
    "language": "zh-CN",
    "memory_system": "layered",
    "token_estimation_cache": {
      "template": {
        "hf": "template-cache/hf"
      },
      "tokenizer": {
        "hf": "tokenizer-cache/hf"
      }
    },
    "time_awareness": {
      "emit_system_date_on_user_message": false,
      "emit_idle_time_gap_hint": true
    },
    "context_compaction": {
      "trigger_ratio": 0.9,
      "token_limit_override": null,
      "recent_fidelity_target_ratio": 0.18
    },
    "idle_compaction": {
      "enabled": false,
      "poll_interval_seconds": 15,
      "min_ratio": 0.5
    },
    "timeout_observation_compaction": {
      "enabled": true
    }
  },
  "sandbox": {
    "mode": "subprocess",
    "bubblewrap_binary": "bwrap",
    "map_docker_socket": false
  },
  "channels": [
    {
      "kind": "telegram",
      "id": "telegram-main",
      "bot_token_env": "TELEGRAM_BOT_TOKEN",
      "api_base_url": "https://api.telegram.org",
      "poll_timeout_seconds": 30,
      "poll_interval_ms": 250,
      "commands": [
        {
          "command": "help",
          "description": "Show available commands"
        },
        {
          "command": "mount",
          "description": "Mount a local folder into bubblewrap for this conversation"
        }
      ]
    }
  ]
}
