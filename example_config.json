{
  "version": "0.6",
  "agent_server": {
    "path": "target/debug/agent_server"
  },
  "models": {
    "main": {
      "provider_type": "open_router_completion",
      "model_name": "openai/gpt-4.1-mini",
      "url": "https://openrouter.ai/api/v1/chat/completions",
      "api_key_env": "OPENROUTER_API_KEY",
      "capabilities": [
        "chat",
        "image_in",
        "pdf_in",
        "audio_in"
      ],
      "token_max_context": 1048576,
      "cache_timeout": 300,
      "conn_timeout": 30,
      "retry_mode": "once",
      "token_estimator_type": "local",
      "multimodal_input": {
        "image": {
          "transport": "inline_base64",
          "supported_media_types": [
            "image/png",
            "image/jpeg",
            "image/webp"
          ],
          "max_width": 4096,
          "max_height": 4096
        },
        "pdf": {
          "transport": "inline_base64",
          "supported_media_types": [
            "application/pdf"
          ]
        },
        "audio": {
          "transport": "inline_base64",
          "supported_media_types": [
            "audio/mpeg",
            "audio/wav",
            "audio/webm",
            "audio/flac",
            "audio/mp4"
          ]
        }
      }
    },
    "search_brave": {
      "provider_type": "brave_search",
      "model_name": "brave-web-search",
      "url": "https://api.search.brave.com/res/v1/web/search",
      "api_key_env": "BRAVE_SEARCH_API_KEY",
      "capabilities": [
        "web_search"
      ],
      "token_max_context": 32768,
      "cache_timeout": 300,
      "conn_timeout": 15,
      "retry_mode": "once",
      "token_estimator_type": "local"
    }
  },
  "session_defaults": {
    "compression_threshold_tokens": 180000,
    "compression_retain_recent_tokens": 36000,
    "search_tool_model": "search_brave"
  },
  "skill_sync": [],
  "sandbox": {
    "mode": "subprocess",
    "bubblewrap_binary": "bwrap",
    "software_dir": null,
    "software_mount_path": "/opt"
  },
  "channels": [
    {
      "kind": "telegram",
      "id": "telegram-main",
      "bot_token_env": "TELEGRAM_BOT_TOKEN",
      "api_base_url": "https://api.telegram.org",
      "poll_timeout_seconds": 30,
      "poll_interval_ms": 250
    }
  ]
}
