{
  "version": "0.2",
  "agent_server": {
    "path": "target/debug/agent_server"
  },
  "models": {
    "main": {
      "type": "openrouter",
      "api_endpoint": "https://openrouter.ai/api/v1",
      "model": "openai/gpt-4.1-mini",
      "api_key_env": "OPENROUTER_API_KEY",
      "chat_completions_path": "/chat/completions",
      "capabilities": [
        "chat",
        "image_in",
        "pdf",
        "audio_in"
      ],
      "multimodal_input": {
        "image": {
          "transport": "inline_base64",
          "supported_media_types": [
            "image/png",
            "image/jpeg",
            "image/webp"
          ],
          "max_width": 4096,
          "max_height": 4096
        },
        "pdf": {
          "transport": "inline_base64",
          "supported_media_types": [
            "application/pdf"
          ]
        },
        "audio": {
          "transport": "inline_base64",
          "supported_media_types": [
            "audio/mpeg",
            "audio/wav",
            "audio/webm",
            "audio/flac",
            "audio/mp4"
          ]
        }
      },
      "context_window_tokens": 1048576,
      "cache_ttl": "5m",
      "timeout_seconds": 30,
      "retry_mode": {
        "mode": "no"
      },
      "token_estimation": {
        "template": {
          "source": "builtin"
        },
        "tokenizer": {
          "source": "tiktoken",
          "encoding": "auto"
        }
      },
      "description": "Default foreground chat model."
    },
    "search_brave": {
      "type": "brave-search",
      "api_endpoint": "https://api.search.brave.com",
      "model": "brave-web-search",
      "api_key_env": "BRAVE_SEARCH_API_KEY",
      "chat_completions_path": "/res/v1/web/search",
      "capabilities": [
        "web_search"
      ],
      "context_window_tokens": 32768,
      "timeout_seconds": 15,
      "retry_mode": {
        "mode": "no"
      },
      "description": "Brave Search provider for web_search."
    }
  },
  "token_estimation_examples": {
    "builtin_template_with_tiktoken": {
      "token_estimation": {
        "template": {
          "source": "builtin"
        },
        "tokenizer": {
          "source": "tiktoken",
          "encoding": "auto"
        }
      }
    },
    "huggingface_repo_short_form": {
      "token_estimation": {
        "source": "huggingface",
        "repo": "Qwen/Qwen2.5-7B-Instruct",
        "revision": "main"
      }
    },
    "huggingface_template_and_tokenizer": {
      "token_estimation": {
        "template": {
          "source": "huggingface",
          "repo": "Qwen/Qwen2.5-7B-Instruct",
          "revision": "main",
          "file": "tokenizer_config.json",
          "field": "chat_template"
        },
        "tokenizer": {
          "source": "huggingface",
          "repo": "Qwen/Qwen2.5-7B-Instruct",
          "revision": "main",
          "file": "tokenizer.json"
        }
      }
    },
    "local_template_and_tokenizer": {
      "token_estimation": {
        "template": {
          "source": "local",
          "path": "path/to/tokenizer_config.json",
          "field": "chat_template"
        },
        "tokenizer": {
          "source": "local",
          "path": "path/to/tokenizer.json"
        }
      }
    }
  },
  "available_models": [
    "main"
  ],
  "tooling": {
    "web_search": "search_brave"
  },
  "main_agent": {
    "enable_context_compression": true,
    "context_compaction": {
      "token_limit_override": 180000,
      "recent_fidelity_target_ratio": 0.2
    }
  },
  "sandbox": {
    "mode": "subprocess",
    "bubblewrap_binary": "bwrap"
  },
  "channels": [
    {
      "kind": "telegram",
      "id": "telegram-main",
      "bot_token_env": "TELEGRAM_BOT_TOKEN",
      "api_base_url": "https://api.telegram.org",
      "poll_timeout_seconds": 30,
      "poll_interval_ms": 250
    }
  ]
}
