{
  "enabled_tools": [
    "read_file",
    "write_file",
    "run_shell",
    "http_request"
  ],
  "upstream": {
    "base_url": "https://api.openai.com/v1",
    "model": "gpt-4.1",
    "api_key_env": "OPENAI_API_KEY",
    "timeout_seconds": 120,
    "context_window_tokens": 128000
  },
  "skills_dirs": [
    "./skills"
  ],
  "system_prompt": "You are a pragmatic agent.",
  "max_tool_roundtrips": 12,
  "workspace_root": ".",
  "enable_context_compression": true,
  "context_compaction": {
    "trigger_ratio": 0.9,
    "token_limit_override": null,
    "recent_fidelity_target_ratio": 0.18
  },
  "timeout_observation_compaction": {
    "enabled": true
  }
}
