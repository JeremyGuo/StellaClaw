{
  "version": "0.4",
  "models": {
    "chat": {
      "claude": {
        "type": "openrouter",
        "api_endpoint": "https://openrouter.ai/api/v1",
        "model": "anthropic/claude-opus-4.6",
        "backend": "agent_frame",
        "supports_vision_input": true,
        "image_tool_model": "self",
        "web_search": "main_web_search",
        "api_key": null,
        "api_key_env": "OPENROUTER_API_KEY",
        "chat_completions_path": "/chat/completions",
        "codex_home": null,
        "auth_credentials_store_mode": "auto",
        "timeout_seconds": 300.0,
        "context_window_tokens": 262144,
        "cache_ttl": "5m",
        "reasoning": null,
        "headers": {},
        "description": "A model better at generating visual content.",
        "native_web_search": {
          "enabled": false,
          "payload": {
            "web_search_options": {
              "search_context_size": "medium"
            }
          }
        }
      },
      "qwen35-27B": {
        "type": "openrouter",
        "api_endpoint": "https://openrouter.ai/api/v1",
        "model": "qwen/qwen3.5-27b",
        "backend": "agent_frame",
        "supports_vision_input": true,
        "image_tool_model": null,
        "web_search": "main_web_search",
        "api_key": null,
        "api_key_env": "OPENROUTER_API_KEY",
        "chat_completions_path": "/chat/completions",
        "codex_home": null,
        "auth_credentials_store_mode": "auto",
        "timeout_seconds": 120.0,
        "context_window_tokens": 262144,
        "cache_ttl": "5m",
        "reasoning": null,
        "headers": {},
        "description": "A cheap model for background long context processing and web search, executing invsible tasks, etc.",
        "native_web_search": {
          "enabled": false,
          "payload": {
            "web_search_options": {
              "search_context_size": "medium"
            }
          }
        }
      }
    },
    "vision": {},
    "web_search": {
      "main_web_search": {
        "base_url": "https://openrouter.ai/api/v1",
        "model": "perplexity/sonar-pro",
        "api_key": null,
        "api_key_env": "OPENROUTER_API_KEY",
        "chat_completions_path": "/chat/completions",
        "timeout_seconds": 60.0,
        "headers": {
          "HTTP-Referer": "https://example.com",
          "X-Title": "AgentHost External Search"
        }
      }
    }
  },
  "main_agent": {
    "model": "claude",
    "timeout_seconds": 0.0,
    "global_install_root": "/opt",
    "language": "zh-CN",
    "enabled_tools": [
      "file_read",
      "file_write",
      "glob",
      "grep",
      "ls",
      "edit",
      "apply_patch",
      "exec_start",
      "exec_observe",
      "exec_wait",
      "exec_kill",
      "file_download_start",
      "file_download_progress",
      "file_download_wait",
      "file_download_cancel",
      "web_fetch",
      "web_search",
      "image_start",
      "image_wait",
      "image_cancel"
    ],
    "max_tool_roundtrips": 120,
    "enable_context_compression": true,
    "context_compaction": {
      "trigger_ratio": 0.9,
      "token_limit_override": null,
      "recent_fidelity_target_ratio": 0.18
    },
    "idle_compaction": {
      "enabled": false,
      "poll_interval_seconds": 15,
      "min_ratio": 0.5
    },
    "timeout_observation_compaction": {
      "enabled": true
    }
  },
  "sandbox": {
    "mode": "subprocess",
    "bubblewrap_binary": "bwrap"
  },
  "max_global_sub_agents": 4,
  "cron_poll_interval_seconds": 5,
  "channels": [
    {
      "kind": "telegram",
      "id": "telegram-main",
      "bot_token": null,
      "bot_token_env": "TELEGRAM_BOT_TOKEN",
      "api_base_url": "https://api.telegram.org",
      "poll_timeout_seconds": 30,
      "poll_interval_ms": 250
    }
  ]
}
